# Exclude everything that doesn't belong in the build context. Smaller
# context = faster builds and smaller images.
.venv/
venv/
__pycache__/
*.py[co]
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
.git/
.github/
*.egg-info/
build/
dist/

# Data & artifacts — pulled at runtime via volumes / MLflow registry, never baked in
data/
mlruns/
mlartifacts/
mlflow.db
feature_store/data/
logs/

# Local secrets — must never enter an image
.env
.env.*
conf/local/credentials.yml

# Editor / OS clutter
.idea/
.vscode/settings.json
.DS_Store

# Notebooks (scratchpads, never run in containers)
*.ipynb
.ipynb_checkpoints/

# Documentation build outputs
docs/_build/
