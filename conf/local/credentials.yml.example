# =============================================================
# conf/local/credentials.yml. LOCAL ONLY, NEVER COMMITTED.
# =============================================================
# Copy this file to credentials.yml and fill in real values.
# The actual credentials.yml is in .gitignore.
# =============================================================

mlflow:
  # Override for Docker. For local dev without Docker use http://localhost:5000.
  tracking_uri: "http://localhost:5000"

# Optional: remote artifact store (S3, GCS, Azure).
